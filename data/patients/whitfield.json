    {
      "fullUrl": "DocumentReference/whitfield_doc_thora_note",
      "resource": {
        "resourceType": "DocumentReference",
        "id": "whitfield_doc_thora_note",
        "meta": {
          "lastUpdated": "2024-09-04T13:00:00-05:00",
          "source": "synthetic"
        },
        "status": "current",
        "docStatus": "final",
        "type": {
          "coding": [
            {
              "system": "http://loinc.org",
              "code": "28570-0",
              "display": "Procedure note"
            }
          ],
          "text": "Thoracentesis procedure note"
        },
        "category": [
          {
            "coding": [
              {
                "system": "http://loinc.org",
                "code": "LP173421-1",
                "display": "Clinical Note"
              }
            ]
          }
        ],
        "subject": {
          "reference": "Patient/whitfield_sample_001"
        },
        "date": "2024-09-04T13:00:00-05:00",
        "author": [
          {
            "display": "Pulmonology, Synthetic MD"
          }
        ],
        "description": "Therapeutic right-sided thoracentesis. 1100 mL serous fluid drained. Procedure prolonged due to patient discomfort despite local anesthesia and PRN IV analgesia; patient repeatedly requested termination. Tolerated procedure poorly. Plan: avoid repeat unless symptom-driven and after explicit reconsent.",

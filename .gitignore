# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# local dev-server log capture
.devserver.log
.devserver.err

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local-only name-scrub mapping references — never commit
docs/.name-scrub-mapping-*.md

# private session records (sensitive context, ThinkPad-local only)
/.private/
.private/

# Epic FHIR sandbox private key — NEVER commit (also caught by *.pem above)
sandbox/private-key.pem
sandbox/*.pem

# Raw Epic FHIR sandbox dumps (one-off probe output) — never commit
scripts/fixtures/

# Field observation notes — private, never committed
docs/observations/
